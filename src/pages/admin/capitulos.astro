---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Capítulos">
  <section data-admin-chapters>
    <div class="section-header">
      <div><span class="eyebrow">Publicação de capítulos</span><h1>Capítulos</h1><p class="muted">Crie e edite capítulos em Markdown, vinculados a obras reais.</p></div>
      <button class="btn soft" type="button" data-new-chapter>Novo capítulo</button>
    </div>
    <div class="notice hidden" data-chapter-message></div>
    <form class="surface admin-form-section" data-chapter-form>
      <h2 data-chapter-form-title>Novo capítulo</h2><p class="hint">Use Markdown simples. Imagens externas podem ser inseridas com <code>![texto alternativo](https://url-da-imagem)</code>.</p>
      <div class="admin-form-grid">
        <div class="field"><label for="work_id">Obra *</label><select id="work_id" name="work_id" required><option value="">Carregando obras...</option></select></div>
        <div class="field"><label for="number">Número</label><input id="number" name="number" type="number" step="0.01" value="1"></div>
        <div class="field"><label for="title">Título *</label><input id="title" name="title" required></div>
        <div class="field"><label for="slug">Slug *</label><input id="slug" name="slug" required></div>
        <div class="field"><label for="publication_status">Publicação</label><select id="publication_status" name="publication_status"><option value="draft">Rascunho</option><option value="scheduled">Agendado</option><option value="published">Publicado</option><option value="hidden">Oculto</option><option value="archived">Arquivado</option></select></div>
        <div class="field"><label for="content_format">Formato</label><select id="content_format" name="content_format"><option value="markdown">Markdown</option><option value="plain">Texto puro</option></select></div>
        <label class="field"><span>Capítulo gratuito</span><input name="is_free" type="checkbox" checked></label>
        <div class="field"><label for="published_at">Publicado em</label><input id="published_at" name="published_at" type="datetime-local"></div>
        <div class="field"><label for="scheduled_at">Agendado para</label><input id="scheduled_at" name="scheduled_at" type="datetime-local"></div>
      </div>
      <div class="field"><label for="excerpt">Resumo</label><textarea id="excerpt" name="excerpt" maxlength="500"></textarea></div>
      <div class="admin-form-grid">
        <div class="field"><label for="content">Conteúdo do capítulo *</label><textarea id="content" name="content" class="editor-textarea" placeholder="Escreva o capítulo aqui..." required></textarea></div>
        <div class="field"><label>Preview básico</label><div class="surface info-card markdown-preview" data-chapter-preview><p class="muted">Preview vazio.</p></div></div>
      </div>
      <div class="admin-form-grid">
        <div class="field"><label for="seo_title">SEO title</label><input id="seo_title" name="seo_title" maxlength="70"></div>
        <div class="field"><label for="seo_description">SEO description</label><textarea id="seo_description" name="seo_description" maxlength="170"></textarea></div>
      </div>
      <div class="admin-form-actions">
        <button class="btn soft" type="submit" data-publication-status="draft">Salvar rascunho</button>
        <button class="btn primary" type="submit" data-publication-status="published">Publicar capítulo</button>
      </div>
    </form>

    <section style="margin-top:1rem;">
      <h2>Capítulos cadastrados</h2>
      <div class="table-wrap"><table><thead><tr><th>Nº</th><th>Título</th><th>Obra</th><th>Status</th><th>Grátis</th><th>Atualização</th><th>Ações</th></tr></thead><tbody data-chapters-body><tr><td colspan="7">Carregando capítulos...</td></tr></tbody></table></div>
    </section>
  </section>
  <script src="/assets/admin-editorial.js" defer></script>
</AdminLayout>
