---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Nova obra">
  <div class="section-header">
    <div><span class="eyebrow">Publicação de novel</span><h1 data-work-form-title>Nova obra</h1><p class="muted">Cadastre, edite, publique, oculte e destaque light novels/webnovels. Capas e banners usam URLs externas.</p></div>
    <div class="actions"><a class="btn soft" href="/admin/obras/">Voltar</a><a class="btn ghost" data-public-preview href="#" hidden target="_blank">Ver no site</a></div>
  </div>
  <div class="notice hidden" data-work-form-message></div>
  <form data-admin-work-form>
    <section class="surface admin-form-section">
      <h2>Informações principais</h2><p class="hint">O slug define a URL pública. Evite mudar depois de publicar.</p>
      <div class="admin-form-grid">
        <div class="field"><label for="title">Título *</label><input id="title" name="title" required minlength="2"></div>
        <div class="field"><label for="subtitle">Subtítulo</label><input id="subtitle" name="subtitle"></div>
        <div class="field"><label for="slug">Slug *</label><input id="slug" name="slug" required></div>
        <div class="field"><label for="author_name">Autor</label><input id="author_name" name="author_name" value="Ryuzen"></div>
        <div class="field"><label for="type">Tipo</label><select id="type" name="type"><option value="light_novel">Light Novel</option><option value="webnovel">Webnovel</option></select></div>
        <div class="field"><label for="status">Status editorial</label><select id="status" name="status"><option value="development">Em desenvolvimento</option><option value="ongoing">Em andamento</option><option value="completed">Concluída</option><option value="paused">Pausada</option></select></div>
        <div class="field"><label for="publication_status">Status de publicação</label><select id="publication_status" name="publication_status"><option value="draft">Rascunho</option><option value="scheduled">Agendada</option><option value="published">Publicada</option><option value="hidden">Oculta</option><option value="archived">Arquivada</option></select></div>
        <div class="field"><label for="language">Idioma</label><input id="language" name="language" value="pt-BR"></div>
        <div class="field"><label for="age_rating">Classificação indicativa</label><input id="age_rating" name="age_rating" placeholder="Livre, 10+, 12+, 14+..."></div>
      </div>
    </section>

    <section class="surface admin-form-section">
      <h2>Descrições</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="short_description">Sinopse curta</label><textarea id="short_description" name="short_description" maxlength="500"></textarea></div>
        <div class="field"><label for="description">Sinopse completa *</label><textarea id="description" name="description" required minlength="20"></textarea></div>
      </div>
      <div class="field"><label for="editorial_notes">Observações internas</label><textarea id="editorial_notes" name="editorial_notes" placeholder="Notas que não aparecem no site público"></textarea></div>
    </section>

    <section class="surface admin-form-section">
      <h2>Imagens externas</h2><p class="hint">Não há upload nesta fase. Cole uma URL pública da capa/banner. Capas verticais de light novel são preservadas sem deformar.</p>
      <div class="admin-form-grid">
        <div><div class="field"><label for="cover_url">URL da capa</label><input id="cover_url" name="cover_url" type="url" placeholder="https://..."></div><div class="field"><label for="cover_alt">Texto alternativo da capa</label><input id="cover_alt" name="cover_alt"></div><div class="field"><label for="cover_credit">Crédito/fonte da capa</label><input id="cover_credit" name="cover_credit"></div><div class="preview-card" data-cover-preview><p class="muted">Cole uma URL para visualizar a capa.</p></div></div>
        <div><div class="field"><label for="banner_url">URL do banner</label><input id="banner_url" name="banner_url" type="url" placeholder="https://..."></div><div class="field"><label for="banner_alt">Texto alternativo do banner</label><input id="banner_alt" name="banner_alt"></div><div class="field"><label for="banner_credit">Crédito/fonte do banner</label><input id="banner_credit" name="banner_credit"></div><div class="preview-card" data-banner-preview><p class="muted">Cole uma URL para visualizar o banner.</p></div></div>
      </div>
    </section>

    <section class="surface admin-form-section">
      <h2>Organização</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="genres">Gêneros</label><input id="genres" name="genres" placeholder="Isekai, Fantasia, Comédia"></div>
        <div class="field"><label for="tags">Tags</label><input id="tags" name="tags" placeholder="Isekai, protagonista, fantasia"></div>
        <label class="field"><span>Obra gratuita</span><input name="is_free" type="checkbox" checked></label>
      </div>
    </section>

    <section class="surface admin-form-section">
      <h2>SEO e links externos</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="seo_title">SEO title</label><input id="seo_title" name="seo_title" maxlength="70"></div>
        <div class="field"><label for="seo_description">SEO description</label><textarea id="seo_description" name="seo_description" maxlength="170"></textarea></div>
        <div class="field"><label for="external_url">Link externo de venda/leitura</label><input id="external_url" name="external_url" type="url" placeholder="https://..."></div>
        <div class="field"><label for="external_label">Rótulo do link externo</label><input id="external_label" name="external_label" placeholder="Comprar na Kirvano, Ler na Amazon..."></div>
      </div>
    </section>

    <section class="surface admin-form-section">
      <h2>Destaque</h2>
      <div class="admin-form-grid">
        <label class="field"><span>Destacar na home</span><input name="is_featured" type="checkbox"></label>
        <div class="field"><label for="featured_priority">Prioridade</label><input id="featured_priority" name="featured_priority" type="number" value="0"></div>
        <div class="field"><label for="featured_label">Rótulo</label><input id="featured_label" name="featured_label" placeholder="Destaque editorial"></div>
        <div class="field"><label for="featured_starts_at">Início do destaque</label><input id="featured_starts_at" name="featured_starts_at" type="datetime-local"></div>
        <div class="field"><label for="featured_ends_at">Fim do destaque</label><input id="featured_ends_at" name="featured_ends_at" type="datetime-local"></div>
      </div>
    </section>

    <section class="surface admin-form-section">
      <h2>Publicação</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="published_at">Data de publicação</label><input id="published_at" name="published_at" type="datetime-local"></div>
        <div class="field"><label for="scheduled_at">Data de agendamento</label><input id="scheduled_at" name="scheduled_at" type="datetime-local"></div>
      </div>
    </section>

    <div class="admin-form-actions">
      <button class="btn ghost" type="submit" data-publication-status="hidden">Salvar oculta</button>
      <button class="btn soft" type="submit" data-publication-status="draft">Salvar rascunho</button>
      <button class="btn primary" type="submit" data-publication-status="published">Publicar agora</button>
    </div>
  </form>
  <script src="/assets/admin-editorial.js" defer></script>
</AdminLayout>
