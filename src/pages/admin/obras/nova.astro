---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Nova obra">
  <span class="eyebrow">Cadastro futuro</span><h1>Nova obra</h1><p class="muted">Formulário protótipo para mapear campos que serão persistidos no D1.</p>
  <form class="surface form-card form-grid"><div class="field"><label for="title">Título</label><input id="title" /></div><div class="field"><label for="slug">Slug</label><input id="slug" /></div><div class="field"><label for="description">Descrição</label><textarea id="description"></textarea></div><button class="btn primary" type="button">Salvar quando API estiver ativa</button></form>
</AdminLayout>
