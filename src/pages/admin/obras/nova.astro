---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Obra editorial">
<div data-admin-work-editor>
  <div class="section-header">
    <div><span class="eyebrow">Publicação de obra</span><h1 data-work-form-title>Nova obra</h1><p class="muted">Informações editoriais, mídia e publicação. Campos internos não aparecem automaticamente no site público.</p></div>
    <div class="actions"><a class="btn soft" href="/admin/obras/">Voltar</a><button class="btn ghost" type="button" data-work-preview>Pré-visualizar página</button><a class="btn ghost" data-public-preview href="#" hidden target="_blank">Ver publicado</a></div>
  </div>
  <div class="notice hidden" data-work-form-message></div>
  <form data-admin-work-form>
    <section class="surface admin-form-section">
      <h2>Informações básicas</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="title">Título principal *</label><input id="title" name="title" required minlength="2"></div>
        <div class="field"><label for="alternate_title">Título alternativo ou abreviado</label><input id="alternate_title" name="alternate_title"></div>
        <div class="field"><label for="subtitle">Subtítulo</label><input id="subtitle" name="subtitle"></div>
        <div class="field"><label for="slug">Slug *</label><input id="slug" name="slug" required><small>Define a URL pública; evite alterar após publicar.</small></div>
        <div class="field"><label for="author_name">Autor</label><input id="author_name" name="author_name" value="Ryuzen"></div>
        <div class="field"><label for="illustrator_name">Ilustrador</label><input id="illustrator_name" name="illustrator_name"></div>
        <div class="field"><label for="type">Tipo</label><select id="type" name="type"><option value="light_novel">Light novel</option><option value="webnovel">Webnovel</option></select><small>One shots serão ativadas em migração futura sem risco ao schema atual.</small></div>
        <div class="field"><label for="status">Status da obra</label><select id="status" name="status"><option value="development">Em desenvolvimento</option><option value="ongoing">Em andamento</option><option value="completed">Concluída</option><option value="paused">Em hiato</option></select></div>
        <div class="field"><label for="publication_status">Status editorial</label><select id="publication_status" name="publication_status"><option value="draft">Rascunho</option><option value="scheduled">Agendada</option><option value="published">Publicada</option><option value="hidden">Oculta</option><option value="archived">Arquivada</option></select></div>
        <div class="field"><label for="language">Idioma</label><input id="language" name="language" value="pt-BR"></div>
      </div>
    </section>
    <section class="surface admin-form-section">
      <h2>Sinopses e descoberta</h2>
      <div class="field"><label for="description">Sinopse da página da obra *</label><textarea id="description" name="description" required minlength="20" rows="5"></textarea></div>
      <div class="field">
        <label for="short_description">Texto promocional curto</label>
        <textarea id="short_description" name="short_description" maxlength="500" rows="3" data-promo-text></textarea>
        <div class="field-meta"><small>Recomendação: 120–160 caracteres para banners e cards compactos.</small><small data-promo-count>0 caracteres</small></div>
        <p class="validation-note hidden" data-promo-warning>Texto acima de 160 caracteres: pode prejudicar banners compactos.</p>
      </div>
      <div class="admin-form-grid">
        <div class="field"><label for="genres">Gêneros</label><input id="genres" name="genres" list="genre-options" placeholder="Fantasia, Comédia, Isekai"><datalist id="genre-options"><option>Fantasia</option><option>Comédia</option><option>Romance</option><option>Isekai</option><option>Mistério</option><option>Drama</option><option>Aventura</option><option>Sobrenatural</option><option>Ação</option><option>Slice of life</option></datalist></div>
        <div class="field"><label for="tags">Tags</label><input id="tags" name="tags" placeholder="templo, magia, humor"></div>
        <div class="field"><label for="age_rating">Classificação indicativa</label><input id="age_rating" name="age_rating" placeholder="Livre, 10+, 12+, 14+..."></div>
        <div class="field"><label for="content_warnings">Avisos de conteúdo</label><input id="content_warnings" name="content_warnings" placeholder="Opcional"></div>
      </div>
    </section>
    <section class="surface admin-form-section media-section">
      <h2>Imagens da obra</h2><p class="hint">Cole URLs públicas. Obras antigas continuam válidas mesmo sem novas imagens opcionais.</p>
      <div class="admin-form-grid media-grid">
        <div class="media-field-card"><div class="field"><label for="cover_url">Capa vertical</label><input id="cover_url" name="cover_url" type="url" placeholder="https://..."><small>Recomendado: proporção 2:3.</small></div><div class="field"><label for="cover_alt">Texto alternativo da capa</label><input id="cover_alt" name="cover_alt"></div><div class="preview-card cover-preview-card" data-cover-preview><p class="muted">Sem capa configurada.</p></div></div>
        <div class="media-field-card"><div class="field"><label for="banner_url">Banner desktop</label><input id="banner_url" name="banner_url" type="url" placeholder="https://..."><small>Recomendado: 16:7.</small></div><div class="field"><label for="mobile_banner_url">Banner mobile</label><input id="mobile_banner_url" name="mobile_banner_url" type="url" placeholder="https://..."><small data-mobile-banner-status>Versão mobile ainda não configurada.</small></div><div class="preview-pair"><div class="preview-card banner-preview-card" data-banner-preview><p class="muted">Sem banner desktop.</p></div><div class="preview-card mobile-banner-preview-card" data-mobile-banner-preview><p class="muted">Sem banner mobile.</p></div></div></div>
      </div>
      <div class="admin-form-grid">
        <div class="field"><label for="social_image_url">Imagem de compartilhamento social</label><input id="social_image_url" name="social_image_url" type="url" placeholder="https://..."></div>
        <div class="field"><label for="banner_alt">Texto alternativo do banner</label><input id="banner_alt" name="banner_alt"></div>
        <div class="field"><label for="cover_credit">Crédito da capa</label><input id="cover_credit" name="cover_credit"></div>
        <div class="field"><label for="banner_credit">Crédito do banner</label><input id="banner_credit" name="banner_credit"></div>
      </div>
    </section>
    <section class="surface admin-form-section">
      <h2>Publicação, acesso e links</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="access_model">Modelo da obra</label><select id="access_model" name="access_model"><option value="free">Gratuita</option><option value="external">Venda/leitura externa</option><option value="mixed">Modelo misto</option></select></div>
        <label class="field"><span>Obra gratuita no catálogo</span><input name="is_free" type="checkbox" checked></label>
        <div class="field"><label for="external_url">Link externo de compra/leitura</label><input id="external_url" name="external_url" type="url" placeholder="https://..."></div>
        <div class="field"><label for="external_label">Texto do botão externo</label><input id="external_label" name="external_label" placeholder="Comprar eBook"></div>
        <div class="field"><label for="published_at">Publicada em</label><input id="published_at" name="published_at" type="datetime-local"></div>
        <div class="field"><label for="scheduled_at">Agendada para</label><input id="scheduled_at" name="scheduled_at" type="datetime-local"></div>
      </div>
    </section>
    <section class="surface admin-form-section">
      <h2>SEO, destaque e notas internas</h2>
      <div class="admin-form-grid">
        <div class="field"><label for="seo_title">Título SEO</label><input id="seo_title" name="seo_title" maxlength="70"></div>
        <div class="field"><label for="seo_description">Descrição SEO</label><textarea id="seo_description" name="seo_description" maxlength="170"></textarea></div>
        <label class="field"><span>Destacar na home</span><input name="is_featured" type="checkbox"></label>
        <div class="field"><label for="featured_priority">Ordem do destaque</label><input id="featured_priority" name="featured_priority" type="number" value="0"></div>
        <div class="field"><label for="featured_label">Rótulo de destaque</label><input id="featured_label" name="featured_label"></div>
      </div>
      <div class="field"><label for="editorial_notes">Observações internas</label><textarea id="editorial_notes" name="editorial_notes"></textarea></div>
    </section>
    <div class="admin-form-actions"><button class="btn ghost" type="submit" data-publication-status="archived">Arquivar</button><button class="btn soft" type="submit" data-publication-status="draft">Salvar rascunho</button><button class="btn primary" type="submit" data-publication-status="published">Publicar agora</button></div>
  </form>
  <dialog class="admin-preview-dialog" data-work-preview-dialog><div class="dialog-header"><h2>Pré-visualização da página da obra</h2><button class="btn ghost" type="button" data-close-preview>Fechar</button></div><div data-work-preview-render></div></dialog>
</div>
<script src="/assets/admin-editorial.v3.js" defer></script>
</AdminLayout>
