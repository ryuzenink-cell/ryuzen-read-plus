---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Criar conta" description="Crie sua conta no Ryuzen Read Plus.">
  <section class="page-section"><div class="container"><div class="surface form-card">
    <span class="eyebrow">Conta</span><h1>Criar conta</h1><p class="muted">No futuro, sua conta salvará biblioteca, progresso, tema e preferências de leitura.</p>
    <form class="form-grid"><div class="field"><label for="name">Nome</label><input id="name" autocomplete="name" /></div><div class="field"><label for="email">Email</label><input id="email" type="email" autocomplete="email" /></div><div class="field"><label for="password">Senha</label><input id="password" type="password" autocomplete="new-password" /></div><button class="btn primary" type="button">Criar quando a API estiver ativa</button></form>
  </div></div></section>
</BaseLayout>
