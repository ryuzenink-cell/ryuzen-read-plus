---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Minha conta" description="Sua central pessoal de leitura na Ryuzen Read Plus.">
  <section class="page-section account-hub-section">
    <div class="container">
      <div class="reader-account" data-reader-account>
        <div class="surface account-loading" aria-live="polite">
          <span class="eyebrow">Conta</span>
          <h1>Minha conta</h1>
          <p class="lead">Preparando sua central de leitura...</p>
        </div>
      </div>
    </div>
  </section>
  <script src="/assets/account-profile.js" defer></script>
</BaseLayout>
