---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';

const emailSubject = encodeURIComponent('Envio de obra para análise editorial — Ryuzen Read Plus');
const emailBody = encodeURIComponent(`Olá, equipe Ryuzen!\n\nGostaria de enviar minha obra para análise editorial.\n\nNome/pseudônimo:\nTítulo da obra:\nTipo (Light Novel ou Webnovel):\nGêneros:\nSinopse breve:\nStatus da obra e quantidade de capítulos:\nLink para leitura ou arquivo:\n\nObrigado(a)!`);
const mailto = `mailto:${SITE.email}?subject=${emailSubject}&body=${emailBody}`;
---
<BaseLayout title="Enviar obra" description="Envie sua light novel ou webnovel para análise editorial da Ryuzen Read Plus por e-mail.">
  <section class="page-section submission-page">
    <div class="container">
      <div class="submission-hero surface">
        <div class="submission-intro">
          <span class="eyebrow">Para autores</span>
          <h1>Apresente sua obra à Ryuzen.</h1>
          <p class="lead">Estamos conhecendo light novels e webnovels autorais para futuras publicações e destaques na Ryuzen Read Plus.</p>
          <p class="muted">O envio é feito diretamente por e-mail para mantermos uma conversa cuidadosa sobre a obra, seus objetivos e a forma mais adequada de apresentá-la aos leitores.</p>
          <a class="submission-email" href={mailto} aria-label={`Enviar obra para ${SITE.email}`}>
            <span>Envie sua obra para</span>
            <strong>{SITE.email}</strong>
          </a>
          <div class="actions">
            <a class="btn primary" href={mailto}>Preparar e-mail de envio</a>
            <a class="btn soft" href="/para-autores/">Conhecer a proposta</a>
          </div>
        </div>

        <aside class="surface submission-summary" aria-label="Resumo do envio">
          <span class="eyebrow">Análise editorial</span>
          <h2>O que procuramos</h2>
          <ul class="submission-checklist">
            <li>Histórias seriadas originais em texto.</li>
            <li>Light novels ou webnovels com identidade própria.</li>
            <li>Obras com sinopse clara e material disponível para avaliação.</li>
            <li>Autores interessados em construir uma apresentação profissional.</li>
          </ul>
        </aside>
      </div>

      <div class="submission-steps">
        <article class="surface submission-card">
          <span class="step-number">01</span>
          <h2>Prepare sua apresentação</h2>
          <p class="muted">Inclua nome ou pseudônimo, título, gênero, tipo de obra, sinopse e o estágio atual do projeto.</p>
        </article>
        <article class="surface submission-card">
          <span class="step-number">02</span>
          <h2>Envie o material</h2>
          <p class="muted">Anexe um arquivo ou envie um link acessível para capítulos, apresentação ou obra publicada.</p>
        </article>
        <article class="surface submission-card">
          <span class="step-number">03</span>
          <h2>Aguarde a análise</h2>
          <p class="muted">Caso a proposta combine com a curadoria da plataforma, entraremos em contato pelo e-mail enviado.</p>
        </article>
      </div>

      <div class="surface submission-details">
        <div>
          <span class="eyebrow">Inclua no e-mail</span>
          <h2>Informações recomendadas</h2>
        </div>
        <ul class="submission-requirements">
          <li><strong>Identificação:</strong> nome do autor ou pseudônimo e contato.</li>
          <li><strong>Obra:</strong> título, tipo — Light Novel ou Webnovel — e gêneros.</li>
          <li><strong>Apresentação:</strong> sinopse breve e público que pretende alcançar.</li>
          <li><strong>Material:</strong> link ou anexo com capítulos disponíveis para leitura.</li>
          <li><strong>Status:</strong> se está em desenvolvimento, finalizada ou já publicada.</li>
          <li><strong>Direitos:</strong> confirme que possui autorização para enviar e publicar o material.</li>
        </ul>
        <p class="submission-note muted">O envio não garante publicação. A análise considera aderência editorial, apresentação e disponibilidade da plataforma.</p>
      </div>
    </div>
  </section>
</BaseLayout>
