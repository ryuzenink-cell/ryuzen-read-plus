---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
---
<BaseLayout title="Gratuitos" description="Novels e capítulos gratuitos para começar a ler no Ryuzen Read Plus.">
  <section class="page-section">
    <div class="container">
      <span class="eyebrow">Comece agora</span>
      <h1>Leia sem cadastro</h1>
      <p class="lead">Conheça novas histórias com capítulos gratuitos e descubra qual delas merece entrar na sua biblioteca.</p>
      <SectionHeader title="Obras abertas para leitura" description="Escolha uma história e comece pelo primeiro capítulo disponível." />
      <div data-free-list></div>
    </div>
  </section>
  <script src="/assets/editorial-public.js" defer></script>
</BaseLayout>
