---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nova senha" description="Crie uma nova senha para sua conta Ryuzen Read Plus.">
  <section class="page-section">
    <div class="container">
      <div class="surface form-card auth-card">
        <span class="eyebrow">Conta</span>
        <h1>Nova senha</h1>
        <p class="muted">Defina uma nova senha para concluir a recuperação da conta.</p>

        <div class="notice hidden" data-auth-message role="status"></div>

        <form class="form-grid" data-reset-form>
          <div class="field">
            <label for="password">Nova senha</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" />
          </div>
          <button class="btn primary" type="submit" data-submit>Atualizar senha</button>
          <p class="auth-links"><a href="/login/">Voltar para login</a></p>
        </form>
      </div>
    </div>
  </section>
  <script is:inline>
    (() => {
      const form = document.querySelector('[data-reset-form]');
      const message = document.querySelector('[data-auth-message]');
      const button = document.querySelector('[data-submit]');
      const token = new URLSearchParams(window.location.search).get('token') || '';
      if (!form || !message || !button) return;

      const show = (text, type = 'info') => {
        message.textContent = text;
        message.className = `notice ${type}`;
      };

      if (!token) {
        show('Token de recuperação ausente. Solicite uma nova recuperação de senha.', 'error');
        button.disabled = true;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        button.disabled = true;
        button.textContent = 'Atualizando...';
        show('Atualizando senha...', 'info');

        const payload = Object.fromEntries(new FormData(form).entries());
        payload.token = token;
        try {
          const response = await fetch('/api/auth/reset-password', {
            method: 'POST',
            credentials: 'include',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await response.json();

          if (!response.ok || !data.ok) {
            show(data.message || 'Não foi possível atualizar a senha.', 'error');
            return;
          }

          show('Senha atualizada. Redirecionando para login...', 'success');
          window.setTimeout(() => window.location.href = '/login/', 900);
        } catch {
          show('Falha de conexão com a API de redefinição.', 'error');
        } finally {
          button.disabled = false;
          button.textContent = 'Atualizar senha';
        }
      });
    })();
  </script>
</BaseLayout>
