---
import ReaderLayout from '../../../layouts/ReaderLayout.astro';
import { works, getWorkBySlug } from '../../../data/works';
import { chapters, getChaptersByWork, getChapter } from '../../../data/chapters';
import { absoluteUrl } from '../../../lib/site';

export function getStaticPaths() {
  return chapters.map((chapter) => ({ params: { slug: chapter.workSlug, chapter: chapter.chapterSlug } }));
}
const { slug, chapter: chapterSlug } = Astro.params;
const work = getWorkBySlug(slug!);
const chapter = getChapter(slug!, chapterSlug!);
if (!work || !chapter) return Astro.redirect('/explorar/');
const list = getChaptersByWork(work.slug);
const index = list.findIndex((item) => item.id === chapter.id);
const prev = list[index - 1];
const next = list[index + 1];
const workUrl = `/obra/${work.slug}/`;
const prevUrl = prev ? `/obra/${work.slug}/${prev.chapterSlug}/` : undefined;
const nextUrl = next ? `/obra/${work.slug}/${next.chapterSlug}/` : undefined;
const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'Chapter',
  name: chapter.title,
  isPartOf: { '@type': 'BookSeries', name: work.title, url: absoluteUrl(workUrl) },
  url: absoluteUrl(`/obra/${work.slug}/${chapter.chapterSlug}/`),
  datePublished: chapter.publishedAt
}];
---
<ReaderLayout title={`${work.title} — ${chapter.title}`} description={chapter.excerpt} workUrl={workUrl} prevUrl={prevUrl} nextUrl={nextUrl} jsonLd={jsonLd}>
  <article class="reader-content">
    <p class="muted"><a href={workUrl}>← {work.title}</a></p>
    <h1>{chapter.title}</h1>
    <p class="lead">{chapter.excerpt}</p>
    {chapter.content.map((paragraph) => <p>{paragraph}</p>)}
  </article>
  <nav class="reader-nav" aria-label="Navegação entre capítulos">
    {prevUrl ? <a class="btn ghost" href={prevUrl}>← Capítulo anterior</a> : <span></span>}
    <a class="btn soft" href={workUrl}>Voltar à obra</a>
    {nextUrl ? <a class="btn primary" href={nextUrl}>Próximo capítulo →</a> : <span></span>}
  </nav>
</ReaderLayout>
