---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Rankings" description="Ranking editorial de light novels e webnovels da Ryuzen Read Plus.">
  <section class="page-section">
    <div class="container">
      <span class="eyebrow">Descoberta</span>
      <h1>Rankings</h1>
      <p class="lead">Por enquanto, o ranking é editorial e controlado no painel admin, sem dados falsos ou obras de exemplo.</p>
      <div data-ranking-list></div>
    </div>
  </section>
  <script src="/assets/editorial-public.js" defer></script>
</BaseLayout>
