---
import BaseLayout from '../layouts/BaseLayout.astro';
import RankingList from '../components/RankingList.astro';
---
<BaseLayout title="Rankings" description="Rankings editoriais e métricas simuladas do catálogo Ryuzen Read Plus.">
  <section class="page-section">
    <div class="container">
      <span class="eyebrow">Descoberta</span>
      <h1>Rankings</h1>
      <p class="lead">Nesta fase, os rankings são editoriais e simulados. No futuro, eles poderão considerar leituras, favoritos e cliques.</p>
      <RankingList />
    </div>
  </section>
</BaseLayout>
