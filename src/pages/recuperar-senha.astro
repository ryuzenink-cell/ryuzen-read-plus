---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Recuperar senha" description="Recupere o acesso à sua conta Ryuzen Read Plus.">
  <section class="page-section"><div class="container"><div class="surface form-card">
    <span class="eyebrow">Conta</span><h1>Recuperar senha</h1><p class="muted">Fluxo preparado para token seguro por email em etapa futura.</p>
    <form class="form-grid"><div class="field"><label for="email">Email cadastrado</label><input id="email" type="email" autocomplete="email" /></div><button class="btn primary" type="button">Enviar instruções quando a API estiver ativa</button></form>
  </div></div></section>
</BaseLayout>
