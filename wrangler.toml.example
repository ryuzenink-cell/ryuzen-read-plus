name = "ryuzen-read-plus"
compatibility_date = "2026-05-20"
pages_build_output_dir = "dist"

[[d1_databases]]
binding = "DB"
database_name = "ryuzen-read-plus-db"
database_id = "COLE_AQUI_O_DATABASE_ID"

